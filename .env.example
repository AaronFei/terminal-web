# terminal-web environment configuration
# Copy to ".env" and adjust as needed. All values are optional; the defaults
# below match src/config.ts. (.env is gitignored.)
#
# NOTE: .env is loaded by scripts/start.sh and scripts/dev.sh (i.e. `npm run
# dev` and `bash scripts/start.sh`). Running `npm start` (tsx) directly does
# NOT auto-load it — in that case export the vars in your shell, e.g.
#   HOST=100.x.y.z PORT=8090 npm start

# Port the HTTP/WebSocket server listens on.
# Default: 8090
PORT=8090

# Address to bind the server to.
# If unset, the server auto-detects your Tailscale IPv4 (via "tailscale ip -4");
# if that fails it falls back to 0.0.0.0 (all interfaces).
# Set this explicitly to pin a specific interface/IP.
# Example: HOST=100.x.y.z
# HOST=

# Default tmux session name used when the client doesn't pass ?session=NAME.
# Session names are sanitized to [A-Za-z0-9_-]{1,64}.
# Default: web
DEFAULT_SESSION=web
